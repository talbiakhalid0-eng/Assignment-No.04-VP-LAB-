@page "/todo-app"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="glass-panel mx-auto" style="max-width: 600px;">
    <h3 style="color: var(--neon-glow);" class="mb-4 text-center">Operation Core Action Manifest</h3>

    <div class="input-group mb-4">
        <input type="text" class="form-control neon-input" placeholder="Queue operational index task item..."
               @bind="TaskInput" @onkeyup="MonitorKeyEvents" />
        <button class="btn btn-neon-magenta" type="button" @onclick="PushTaskToCollection">Queue Item</button>
    </div>

    <div class="task-stream my-3" style="max-height: 250px; overflow-y: auto;">
        @if (InMemoryTasks.Count == 0)
        {
            <p class="text-muted text-center py-3 italic">No tasks active within current local volatile storage structures.</p>
        }
        else
        {
            @foreach (var task in InMemoryTasks)
            {
                <div class="p-2 mb-2 rounded border" style="background: rgba(255,255,255,0.01); border-color: var(--border-glass) !important;">
                    <span class="text-white-50"><i class="bi bi-terminal me-2 text-info"></i> @task</span>
                </div>
            }
        }
    </div>

    @if (InMemoryTasks.Count > 0)
    {
        <button class="btn btn-sm btn-outline-danger w-100 mt-2" @onclick="ClearVolatileRegistry">
            Purge Buffer Arrays (Clear All)
        </button>
    }
</div>

@code {
    private List<string> InMemoryTasks { get; set; } = new();
    private string TaskInput { get; set; } = string.Empty;

    private void PushTaskToCollection()
    {
        if (!string.IsNullOrWhiteSpace(TaskInput))
        {
            InMemoryTasks.Add(TaskInput.Trim());
            TaskInput = string.Empty;
        }
    }

    private void MonitorKeyEvents(KeyboardEventArgs e) { if (e.Key == "Enter") PushTaskToCollection(); }
    private void ClearVolatileRegistry() => InMemoryTasks.Clear();
}
