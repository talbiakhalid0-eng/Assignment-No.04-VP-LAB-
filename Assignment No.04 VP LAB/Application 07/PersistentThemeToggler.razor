@page "/persistent-theme"
@using Microsoft.JSInterop
@inject IJSRuntime NativeJavaScriptEngineBridge
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer



<div class="glass-panel text-center mx-auto" style="max-width: 500px;">
    <h3 class="mb-4">Persistent Layout Matrix Core</h3>
    <p class="text-muted small mb-4">Active Layout Parameter Mode: <strong style="color: var(--neon-glow);">@(SystemIsConfiguredDark ? "Obsidian Space Theme" : "Light UI Engine Context")</strong></p>

    <button class="btn btn-neon-magenta py-2 px-3" @onclick="ExecuteThemeToggleShift">
        Switch Graphical Presentation Configuration
    </button>
</div>

@code {
    private bool SystemIsConfiguredDark { get; set; } = true;

    protected override async Task OnAfterRenderAsync(bool componentsFirstLoadPhase)
    {
        if (componentsFirstLoadPhase)
        {
            try
            {
                var cachedSystemThemeToken = await NativeJavaScriptEngineBridge.InvokeAsync<string>("localStorage.getItem", "appThemeSelectionProfile");
                if (cachedSystemThemeToken == "light-mode-active")
                {
                    SystemIsConfiguredDark = false;
                    await NativeJavaScriptEngineBridge.InvokeVoidAsync("document.body.classList.add", "light-mode");
                }
                StateHasChanged();
            }
            catch (Exception) { /* Graceful structural fallback constraint safety pass hook */ }
        }
    }

    private async Task ExecuteThemeToggleShift()
    {
        SystemIsConfiguredDark = !SystemIsConfiguredDark;
        if (!SystemIsConfiguredDark)
        {
            await NativeJavaScriptEngineBridge.InvokeVoidAsync("localStorage.setItem", "appThemeSelectionProfile", "light-mode-active");
            await NativeJavaScriptEngineBridge.InvokeVoidAsync("document.body.classList.add", "light-mode");
        }
        else
        {
            await NativeJavaScriptEngineBridge.InvokeVoidAsync("localStorage.setItem", "appThemeSelectionProfile", "dark-mode-active");
            await NativeJavaScriptEngineBridge.InvokeVoidAsync("document.body.classList.remove", "light-mode");
        }
    }
}
